# Gateway base URL (NestJS, /api/v1 prefix). EXPO_PUBLIC_ vars are inlined at
# bundle time and reachable from the JS bundle. Restart Metro after changes.
# iOS simulator reaches the host machine via localhost.
EXPO_PUBLIC_API_URL=http://localhost:3333/api/v1

# Supabase auth. Both values are public/publishable (safe to inline). Find them
# in the dashboard under Settings → API. For the key, use the new "Publishable
# key" (sb_publishable_...); on legacy projects it's the "anon public" key.
# Never use the secret/service_role key here.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
