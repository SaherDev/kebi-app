DATABASE_URL=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# Supabase auth (used when auth.provider: supabase). The JWKS URL is derived as
# ${SUPABASE_PROJECT_URL}/auth/v1/.well-known/jwks.json unless SUPABASE_JWKS_URL
# overrides it. No secret is needed — JWKS verification uses public keys.
SUPABASE_PROJECT_URL=
SUPABASE_JWKS_URL=
APP_CORS_ORIGINS=
AI_SERVICE_BASE_URL=
# Shared secret for service-to-service auth with kebi. Must match kebi's
# GATEWAY_SHARED_SECRET byte-for-byte; rotate on both sides in one deploy.
# Generate with: openssl rand -hex 32
GATEWAY_SHARED_SECRET=
APP_DEV_BYPASS_ENABLED=
DEV_BYPASS_TOKEN=
DEV_BYPASS_USER_ID=
