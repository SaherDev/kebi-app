DATABASE_URL=
# Supabase auth (used when auth.provider: supabase). The JWKS URL is derived as
# ${SUPABASE_PROJECT_URL}/auth/v1/.well-known/jwks.json unless SUPABASE_JWKS_URL
# overrides it. Token verification uses public JWKS keys (no secret needed).
SUPABASE_PROJECT_URL=
# Optional override; leave unset (commented) to auto-derive from SUPABASE_PROJECT_URL.
# SUPABASE_JWKS_URL=
# Service-role key (Settings → API). Server-only — NEVER ship to a client.
# Used by the Admin API to stamp internal_id/plan into the user's app_metadata
# so future tokens carry them (claim-first, no per-request DB hit). Stamping is
# skipped (fail-open) when this is unset.
SUPABASE_SERVICE_ROLE_KEY=
# Encrypts our app_metadata claims (internal_id/plan) so they're opaque in the token.
# KEY: 16-byte hex / AES-128 (openssl rand -hex 16). FIELD: a short random
# app_metadata key name, e.g. kebi_<rand>; leave unset to use the built-in default.
KEBI_APP_METADATA_KEY=
KEBI_APP_METADATA_FIELD=
APP_CORS_ORIGINS=
KEBI_BASE_URL=
# Shared secret for service-to-service auth with kebi. Must match kebi's
# GATEWAY_SHARED_SECRET byte-for-byte; rotate on both sides in one deploy.
# Generate with: openssl rand -hex 32
GATEWAY_SHARED_SECRET=
APP_DEV_BYPASS_ENABLED=
DEV_BYPASS_TOKEN=
DEV_BYPASS_USER_ID=
